<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#01432A"
    tools:ignore="HardcodedText,UseCompoundDrawables">

    <RelativeLayout
        android:id="@+id/layoutPaymentHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#01432A"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/btnBackPayment"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="Back Button"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thanh toán hóa đơn"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutPaymentHeader"
        android:layout_above="@id/layoutBottomPaymentButton"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Thông tin đơn đặt sân"
                android:textStyle="bold"
                android:textColor="#FACC15"
                android:textSize="15sp"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#025938"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtPayCourtName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sân số 1 - Cụm Đại Học Vinh"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/txtPayDateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lịch đá: 19/05/2026 | 17:30 - 19:00"
                        android:textSize="14sp"
                        android:textColor="#CBD5E1"
                        android:layout_marginTop="6dp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#047857"
                        android:layout_marginVertical="12dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng số tiền cần thanh toán:"
                            android:textColor="#E2E8F0"
                            android:textSize="14sp"
                            android:layout_centerVertical="true"/>
                        <TextView
                            android:id="@+id/txtPayTotalAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="200,000 đ"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#FACC15"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 Chọn phương thức thanh toán"
                android:textStyle="bold"
                android:textColor="#FACC15"
                android:textSize="15sp"
                android:layout_marginBottom="12dp"/>

            <RadioGroup
                android:id="@+id/radioGroupPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/radioCod"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="💵 Tiền mặt tại sân (Trả sau)"
                    android:background="@android:drawable/editbox_background_normal"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="12dp"
                    android:buttonTint="#EAB308"
                    android:textColor="#01432A"
                    android:textStyle="bold"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/radioQr"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🏦 Chuyển khoản ngân hàng qua mã QR"
                    android:background="@android:drawable/editbox_background_normal"
                    android:paddingHorizontal="12dp"
                    android:textColor="#01432A"
                    android:textStyle="bold"
                    android:buttonTint="#EAB308"/>
            </RadioGroup>

            <LinearLayout
                android:id="@+id/layoutQrContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="24dp"
                android:padding="20dp"
                android:background="@android:drawable/dialog_holo_light_frame"
                android:elevation="3dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quét mã QR bằng App Ngân hàng của bạn"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:id="@+id/imgQrCodePayment"
                        android:layout_width="210dp"
                        android:layout_height="210dp"
                        android:src="@android:drawable/ic_menu_report_image"
                        android:background="#F8FAFC"
                        android:padding="8dp"
                        android:contentDescription="Mã QR Chuyển Khoản Ngân Hàng" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/txtQrContentHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nội dung CK: DATSAN XXXXX"
                    android:textColor="#B45309"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomPaymentButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#01432A"
        android:padding="16dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnFinalizePayment"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="XAC NHẬN ĐẶT SÂN"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#01432A"
            android:backgroundTint="#EAB308"
            app:cornerRadius="12dp" />
    </LinearLayout>

</RelativeLayout>