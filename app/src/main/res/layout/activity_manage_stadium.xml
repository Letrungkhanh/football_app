<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:id="@+id/layoutHeaderManagement"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#015938"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingHorizontal="16dp">
            <ImageView
                android:id="@+id/btnBackManagement"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF" />
            <TextView
                android:id="@+id/txtManagementTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Quản lý cụm sân"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnSearchInline"
                android:layout_width="46dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_management_btn"
                android:padding="12dp"
                android:src="@android:drawable/ic_input_add"
                app:tint="#FFFFFF" />

            <LinearLayout
                android:id="@+id/btnFilterStatus"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_management_btn"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tất cả tỉnh" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_marginStart="8dp" android:src="@android:drawable/ic_menu_manage" app:tint="#FFFFFF"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnSortAZ"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_management_btn"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A->Z" android:textColor="#FFFFFF" android:textSize="14sp"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_marginStart="8dp" android:src="@android:drawable/ic_menu_sort_alphabetically" app:tint="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnSelectBranchInline"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_management_btn"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">
            <TextView
                android:id="@+id/txtCurrentBranchName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hệ thống tổng hợp chi nhánh"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />
            <ImageView android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_menu_share" app:tint="#FFFFFF"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hoạt động" android:textColor="#A7F3D0" android:textSize="14sp" android:textStyle="bold"/>

            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1"/>

            <TextView android:id="@+id/txtCountTotal" android:text="0" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_marginStart="4dp" android:src="@android:drawable/btn_star_big_on" app:tint="#4ADE80"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutTableLabel"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_below="@id/layoutHeaderManagement"
        android:background="#004D30"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">
        <TextView android:layout_width="50dp" android:layout_height="wrap_content" android:text="STT" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" android:textSize="14sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tên cụm sân lớn" android:textColor="#FFFFFF" android:textStyle="bold" android:paddingStart="8dp" android:textSize="14sp" />
        <TextView android:layout_width="150dp" android:layout_height="wrap_content" android:text="Địa chỉ chi tiết" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="14sp"/>
        <View android:layout_width="40dp" android:layout_height="match_parent"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewManagementData"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutTableLabel"
        android:cacheColorHint="#00000000" />

</RelativeLayout>