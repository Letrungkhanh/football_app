<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtHistoryCourtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sân Số 1 - Sân Lam Thành"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtHistoryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Đã duyệt"
                android:textStyle="bold"
                android:textColor="#10B981"
                android:textSize="13sp"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/txtHistoryDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📅 Thời gian: 17:00 - 18:30 | 18/05/2026"
            android:textColor="#475569"
            android:textSize="14sp"
            android:layout_marginTop="8dp"/>
        <TextView
            android:id="@+id/txtUserBookingServices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🥤 Dịch vụ: Nước suối x2, Sting x1"
            android:textColor="#2563EB"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txtHistoryPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 Tổng tiền: 300,000đ"
            android:textStyle="bold"
            android:textColor="#EF4444"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>