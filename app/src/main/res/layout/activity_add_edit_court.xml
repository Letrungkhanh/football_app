<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    tools:ignore="HardcodedText">

    <RelativeLayout
        android:id="@+id/layoutHeaderAddEditCourt"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#015938"
        android:paddingHorizontal="16dp">
        <ImageView
            android:id="@+id/btnBackAddEditCourt"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/txtAddEditCourtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thông tin sân bóng nhỏ"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layoutBottomButtonCourt"
        android:layout_below="@id/layoutHeaderAddEditCourt"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên sân nhỏ (Ví dụ: Sân số 1)"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtCourtName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Nhập tên sân bóng"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giá thuê mỗi giờ (VNĐ)"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtCourtPrice"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ví dụ: 200000"
                android:inputType="number"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã cụm sân lớn (Stadium ID)"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtStadiumId"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ví dụ: stadium1"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loại sân (Kích thước)"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtCourtType"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ví dụ: 5 người, 7 người"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Trạng thái sân"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtCourtStatus"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ví dụ: available, maintenance"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomButtonCourt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F1F5F9"
        android:padding="16dp"
        android:orientation="vertical">
        <Button
            android:id="@+id/btnSaveCourt"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="LƯU THÔNG TIN SÂN NHỎ"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#01432A"
            android:backgroundTint="#EAB308"
            app:cornerRadius="12dp" />
    </LinearLayout>

</RelativeLayout>