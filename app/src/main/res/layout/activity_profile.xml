<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:ignore="HardcodedText,Autofill">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:background="#01432A"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="Tài khoản cá nhân"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-70dp"
                android:paddingHorizontal="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        app:cardCornerRadius="48dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardElevation="6dp">

                        <TextView
                            android:id="@+id/txtAvatarHint"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="👤"
                            android:textSize="44sp"
                            android:gravity="center"
                            android:contentDescription="User Avatar" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/txtProfileEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="user@gmail.com"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1E293B"
                        android:layout_marginTop="12dp" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="28dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Họ và tên"
                            android:textStyle="bold"
                            android:textColor="#475569"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/edtProfileName"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="Nhập họ tên của bạn"
                            android:inputType="textPersonName"
                            android:paddingHorizontal="16dp"
                            android:textColor="#1E293B"
                            android:textColorHint="#94A3B8"
                            android:textSize="15sp"
                            android:background="@drawable/bg_edit_text"
                            android:layout_marginBottom="20dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số điện thoại"
                            android:textStyle="bold"
                            android:textColor="#475569"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/edtProfilePhone"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="Nhập số điện thoại nhận sân"
                            android:inputType="phone"
                            android:paddingHorizontal="16dp"
                            android:textColor="#1E293B"
                            android:textColorHint="#94A3B8"
                            android:textSize="15sp"
                            android:background="@drawable/bg_edit_text" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnBookingHistory"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Lịch sử đơn đặt sân"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#10B981"
                    android:backgroundTint="#FFFFFF"
                    app:strokeColor="#10B981"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="1dp" />

                <Button
                    android:id="@+id/btnSaveProfile"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Cập nhật thông tin"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#10B981"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="24dp"
                    android:elevation="2dp" />
                <Button
                    android:id="@+id/btnProfileLogout"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Đăng xuất tài khoản"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#EF4444"
                    android:backgroundTint="#FEE2E2"
                    app:strokeColor="#FCA5A5"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="24dp"
                    android:elevation="0dp" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>