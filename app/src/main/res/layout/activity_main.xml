<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:ignore="HardcodedText,StringFormatInvalid">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:background="#10B981"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp">

                <TextView
                    android:id="@+id/txtHeaderDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thứ sáu, 22/05/2026"
                    android:textColor="#E0F2FE"
                    android:textSize="14sp"
                    android:textStyle="normal" />

                <LinearLayout
                    android:id="@+id/layoutAuthButtons"
                    style="?android:attr/buttonBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/txtHeaderDate"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnHomeLogin"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:backgroundTint="#FFFFFF"
                        android:text="Đăng nhập"
                        android:textAllCaps="false"
                        android:textColor="#10B981"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp" />

                    <Button
                        android:id="@+id/btnHomeRegister"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#047857"
                        android:text="Đăng ký"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        app:cornerRadius="8dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgUserProfile"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignTop="@id/txtHeaderDate"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:contentDescription="Profile Icon" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="-65dp"
                android:paddingHorizontal="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    app:cardCornerRadius="27dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_search"
                            app:tint="#10B981"
                            android:contentDescription="Search Icon" />

                        <EditText
                            android:id="@+id/edtHomeSearch"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="Tìm kiếm sân bóng, cụm sân phủi..."
                            android:textColorHint="#94A3B8"
                            android:paddingHorizontal="10dp"
                            android:textSize="14sp"
                            android:inputType="text"
                            android:importantForAutofill="no"
                            tools:ignore="Autofill" />

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#64748B"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="QR Scanner" />

                        <ImageView
                            android:id="@+id/btnFavoriteList"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@android:drawable/btn_star"
                            app:tint="#64748B"
                            android:contentDescription="Favorites List" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingVertical="4dp">

                        <LinearLayout
                            android:id="@+id/catFootball"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="12dp"
                            tools:ignore="UseCompoundDrawables">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@android:drawable/dialog_holo_light_frame"
                                android:padding="10dp"
                                android:src="@android:drawable/ic_media_play"
                                android:contentDescription="Bóng đá" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bóng đá"
                                android:textSize="12sp"
                                android:textColor="#334155"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/catBadminton"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="12dp"
                            tools:ignore="UseCompoundDrawables">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@android:drawable/dialog_holo_light_frame"
                                android:padding="10dp"
                                android:src="@android:drawable/ic_menu_compass"
                                android:contentDescription="Cầu lông" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cầu lông"
                                android:textSize="12sp"
                                android:textColor="#334155"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/catPickleball"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="12dp"
                            tools:ignore="UseCompoundDrawables">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@android:drawable/dialog_holo_light_frame"
                                android:padding="10dp"
                                android:src="@android:drawable/ic_menu_agenda"
                                android:contentDescription="Pickleball" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pickleball"
                                android:textSize="12sp"
                                android:textColor="#334155"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/catVolleyball"
                            android:layout_width="72dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            tools:ignore="UseCompoundDrawables">
                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@android:drawable/dialog_holo_light_frame"
                                android:padding="10dp"
                                android:src="@android:drawable/ic_menu_directions"
                                android:contentDescription="Bóng chuyền" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bóng chuyền"
                                android:textSize="12sp"
                                android:textColor="#334155"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bóng đá gần tôi"
                            android:textSize="13sp"
                            android:textColor="#475569"
                            android:background="@android:drawable/editbox_background_normal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sân mở cửa muộn"
                            android:textSize="13sp"
                            android:textColor="#475569"
                            android:background="@android:drawable/editbox_background_normal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vé rẻ gần tôi"
                            android:textSize="13sp"
                            android:textColor="#475569"
                            android:background="@android:drawable/editbox_background_normal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"/>
                    </LinearLayout>
                </HorizontalScrollView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✨ Cụm sân bóng nổi bật"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewUserStadiums"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>