<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9"
    tools:ignore="HardcodedText">

    <RelativeLayout
        android:id="@+id/layoutHeaderAddEdit"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#015938"
        android:paddingHorizontal="16dp">
        <ImageView
            android:id="@+id/btnBackAddEdit"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true" />
        <TextView
            android:id="@+id/txtAddEditTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Thông tin cụm sân lớn"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layoutBottomButton"
        android:layout_below="@id/layoutHeaderAddEdit"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên cụm sân (Ví dụ: Đại học Vinh)"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtStadiumName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Nhập tên cụm sân"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Địa chỉ chi tiết"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtStadiumAddress"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ví dụ: 182 Lê Duẩn"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thành phố / Tỉnh"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtStadiumCity"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ví dụ: Vinh"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quận / Huyện"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtStadiumDistrict"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Ví dụ: Bến Thủy"
                android:inputType="text"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Link hình ảnh sân bóng"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <EditText
                android:id="@+id/edtStadiumImage"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Dán link ảnh tại đây (hoặc để trống)"
                android:inputType="textUri"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_input_field"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"
                android:importantForAutofill="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Môn thể thao áp dụng"
                android:textStyle="bold"
                android:textColor="#334155"
                android:textSize="14sp"
                android:layout_marginBottom="6dp" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="24dp">
                <Spinner
                    android:id="@+id/spinnerStadiumCategory"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="4dp"
                    android:spinnerMode="dropdown" />
            </FrameLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#F1F5F9"
        android:padding="16dp"
        android:orientation="vertical">
        <Button
            android:id="@+id/btnSaveStadium"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="LƯU THÔNG TIN CỤM SÂN"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#01432A"
            android:backgroundTint="#EAB308"
            app:cornerRadius="12dp" />
    </LinearLayout>

</RelativeLayout>